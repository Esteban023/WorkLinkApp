<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragmentos.HomeFragment"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textInicial"
                android:layout_width="118dp"
                android:layout_height="34dp"
                android:layout_margin="11dp"
                android:layout_marginLeft="0dp"
                android:text="WorkLink"
                android:textAlignment="center"
                android:textColor="@color/brand_primary"
                android:textSize="22dp" />
        </LinearLayout>

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/main_fragment"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:defaultNavHost="true"
            app:navGraph="@navigation/nav_graph" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/neutral02"/>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/nav_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:backgroundTint="@android:color/transparent"
            app:itemActiveIndicatorStyle="@style/navIndicatorStyle"
            app:itemGravity="center"
            app:itemIconTint="@color/nav_text_color"
            app:itemRippleColor="@android:color/transparent"
            app:itemTextColor="@color/nav_text_color"
            app:menu="@menu/menu_main" />
    </LinearLayout>
</FrameLayout>